{
  "name": "codex-metrics",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "metrics:generate": "bun run tools/generate-metrics.ts",
    "metrics:watch": "bun run tools/watch-metrics.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src",
    "biome": "biome check src package.json tsconfig.json biome.json",
    "test": "bun test",
    "verify": "bun run typecheck && bun run lint && bun run biome && bun run test && bun run build",
    "agent:loop": "bun run tools/agent-loop.ts",
    "agent:loop:dry": "bun run tools/agent-loop.ts -- --dry-run"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
