{
  "name": "codex-metrics",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "collect": "bun run scripts/collect-codex-metrics.ts",
    "dev": "bun run collect && vite --host 127.0.0.1",
    "build": "bun run collect && tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src scripts vite.config.ts",
    "biome": "biome check src scripts vite.config.ts mockups package.json tsconfig.json biome.json index.html TODO.md",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  }
}
