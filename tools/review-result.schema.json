{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "summary", "issues", "verification"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["lgtm", "changes_requested"]
    },
    "summary": {
      "type": "string"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "issue", "fix"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["blocker", "major", "minor"]
          },
          "file": {
            "type": "string"
          },
          "line": {
            "type": "integer",
            "minimum": 1
          },
          "issue": {
            "type": "string"
          },
          "fix": {
            "type": "string"
          }
        }
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
